# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.ipynb_checkpoints/

# --- Virtual envs ---
.venv/
venv/
env/

# --- Environment / secrets ---
.env
*.local

# --- Data & model artifacts: tracked by DVC, never committed to git ---
# Ignore heavy artifacts BY TYPE. DVC's own *.dvc pointer files and the
# per-directory .gitignore files it generates are NOT matched here, so they
# stay tracked in git and let anyone `dvc pull` the real data.
*.csv
*.tsv
*.parquet
*.feather
*.pkl
*.joblib
*.h5
*.hdf5
*.zip
*.gz
# Trained model binaries (keep *.dvc pointers tracked)
models/*.txt
models/*.json
models/*.cbm
models/*.ubj
models/*.bin

# Phase-2 calibrator: committed deliberately (small, Phase-4-findable). The *.joblib
# global rule above would otherwise ignore it; the portable JSON manifest beside it is
# the version-checked source of truth, the joblib is the fitted-object companion.
!models/calibration/
!models/calibration/calibrator.joblib

# Phase-3 fairness audit tables: committed deliberately (small, provenance-bearing).
# The models/*.json global rule above would otherwise ignore them.
!models/fairness/
!models/fairness/*.json

# --- Experiment tracking ---
mlruns/
mlartifacts/
.dvc/cache/
.dvc/tmp/

# --- Tooling caches ---
.pytest_cache/
.ruff_cache/
.mypy_cache/
htmlcov/
.coverage

# --- IDE / OS ---
.vscode/
.idea/
.DS_Store
Thumbs.db
