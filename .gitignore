# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.ipynb_checkpoints/

# --- Virtual envs ---
.venv/
venv/
env/

# --- Environment / secrets ---
.env
*.local

# --- Data & model artifacts: tracked by DVC, never committed to git ---
# Ignore heavy artifacts BY TYPE. DVC's own *.dvc pointer files and the
# per-directory .gitignore files it generates are NOT matched here, so they
# stay tracked in git and let anyone `dvc pull` the real data.
*.csv
*.tsv
*.parquet
*.feather
*.pkl
*.joblib
*.h5
*.hdf5
*.zip
*.gz
# Trained model binaries (keep *.dvc pointers tracked)
models/*.txt
models/*.json
models/*.cbm
models/*.ubj
models/*.bin

# --- Experiment tracking ---
mlruns/
mlartifacts/
.dvc/cache/
.dvc/tmp/

# --- Tooling caches ---
.pytest_cache/
.ruff_cache/
.mypy_cache/
htmlcov/
.coverage

# --- IDE / OS ---
.vscode/
.idea/
.DS_Store
Thumbs.db
